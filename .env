# ============================================
# 🏸 BaBadminton — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# ── MySQL Database ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=babadminton

# ── Google OAuth (optional — skip if not using) ──

# ── Session ──
SESSION_SECRET=babadminton-secret-key-change-this

# ── Server ──
PORT=3000
