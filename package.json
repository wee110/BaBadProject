{
  "name": "babadminton-booking",
  "version": "2.0.0",
  "description": "\ud83c\udff8 BaBadminton Court Booking System",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "test": "jest --verbose --testPathIgnorePatterns=tests/e2e",
    "test:coverage": "jest --coverage --collectCoverageFrom=\"model/**/*.js\" --coverageReporters=text --coverageReporters=text-summary --testPathIgnorePatterns=tests/e2e",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "migrate": "node migrate.js up",
    "migrate:rollback": "node migrate.js down",
    "migrate:status": "node migrate.js status",
    "security:setup": "node scripts/security-setup.js",
    "docker:build": "docker build -t babadminton:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "connect-flash": "^0.1.1",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mysql2": "^3.6.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^29.7.0"
  }
}
