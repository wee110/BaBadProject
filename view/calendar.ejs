<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="ปฏิทินการจองสนามแบดมินตัน">
    <title>BaBadminton — ปฏิทิน</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="bg-decoration"></div>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/dashboard" class="navbar-brand">
                <span class="icon">🏸</span>
                <span>BaBadminton</span>
            </a>
            <div class="navbar-nav">
                <a href="/dashboard" class="nav-link" id="nav-dashboard">📊 Dashboard</a>
                <a href="/search" class="nav-link" id="nav-search">🔍 ค้นหาสนาม</a>
                <a href="/calendar" class="nav-link active" id="nav-calendar">📅 ปฏิทิน</a>
                <div class="nav-user">
                    <div class="avatar"><%= user.username.charAt(0).toUpperCase() %></div>
                    <div class="user-info">
                        <span class="user-name"><%= user.username %></span>
                        <span class="user-role"><%= user.role %></span>
                    </div>
                </div>
                <a href="/logout" class="nav-link" id="nav-logout">🚪 ออก</a>
            </div>
        </div>
    </nav>

    <div class="page-container">
        <%
            const today = new Date();
            const offset = monthOffset || 0;
            const viewDate = new Date(today.getFullYear(), today.getMonth() + offset, 1);
            const year = viewDate.getFullYear();
            const month = viewDate.getMonth();
            const monthNames = ['มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน',
                                'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม'];
            const firstDay = new Date(year, month, 1);
            const lastDay = new Date(year, month + 1, 0);
            const startDate = new Date(firstDay);
            startDate.setDate(startDate.getDate() - firstDay.getDay());
        %>

        <!-- Page Header -->
        <div class="page-header">
            <h1 class="page-title">📅 ปฏิทินการจอง</h1>
            <p class="page-subtitle">ดูภาพรวมการจองสนามทั้งหมด</p>
        </div>

        <!-- Calendar Navigation -->
        <div class="calendar-nav">
            <div class="calendar-nav-btns">
                <a href="/calendar?month=<%= offset - 1 %>" class="btn btn-secondary btn-sm" id="btn-prev-month">← เดือนก่อน</a>
            </div>
            <h3><%= monthNames[month] %> <%= year %></h3>
            <div class="calendar-nav-btns">
                <a href="/calendar?month=<%= offset + 1 %>" class="btn btn-secondary btn-sm" id="btn-next-month">เดือนถัดไป →</a>
            </div>
        </div>

        <!-- Calendar Grid -->
        <div class="calendar-grid">
            <div class="calendar-header">อา</div>
            <div class="calendar-header">จ</div>
            <div class="calendar-header">อ</div>
            <div class="calendar-header">พ</div>
            <div class="calendar-header">พฤ</div>
            <div class="calendar-header">ศ</div>
            <div class="calendar-header">ส</div>

            <% for (let i = 0; i < 42; i++) {
                const currentDate = new Date(startDate);
                currentDate.setDate(startDate.getDate() + i);
                const dateStr = currentDate.toISOString().split('T')[0];
                const dayBookings = bookings.filter(b => b.date === dateStr);
                const isToday = currentDate.toDateString() === today.toDateString();
                const isCurrentMonth = currentDate.getMonth() === month;
            %>
                <div class="calendar-day <%= isToday ? 'today' : '' %> <%= !isCurrentMonth ? 'other-month' : '' %>">
                    <div class="day-number"><%= currentDate.getDate() %></div>
                    <% dayBookings.forEach(booking => { %>
                        <% const court = courts.find(c => c.id === booking.courtId) %>
                        <% const bookingUser = users.find(u => u.id === booking.userId) %>
                        <div class="calendar-booking <%= booking.status %>"
                             title="<%= court ? court.name : 'สนาม' %> | <%= booking.startTime %>-<%= booking.endTime %> | <%= bookingUser ? bookingUser.username : 'ไม่ทราบ' %> | <%= booking.status %>">
                            <%= court ? court.name : 'สนาม' %>
                            <br><%= booking.startTime %>-<%= booking.endTime %>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Legend -->
        <div class="calendar-legend">
            <div class="legend-item">
                <div class="legend-dot approved"></div>
                อนุมัติแล้ว
            </div>
            <div class="legend-item">
                <div class="legend-dot pending"></div>
                รอการอนุมัติ
            </div>
        </div>

        <!-- All Bookings List -->
        <div class="section-header">
            <h2 class="section-title">📋 รายการจองทั้งหมด</h2>
        </div>

        <% if (bookings.length === 0) { %>
            <div class="empty-state glass-card" style="padding: 48px;">
                <div class="icon">📭</div>
                <p>ยังไม่มีการจอง</p>
            </div>
        <% } else { %>
            <div class="bookings-list">
                <% bookings.forEach(booking => { %>
                    <% const court = courts.find(c => c.id === booking.courtId) %>
                    <% const bookingUser = users.find(u => u.id === booking.userId) %>
                    <div class="booking-card status-<%= booking.status %>">
                        <div class="booking-info">
                            <div class="booking-court-name">
                                🏸 <%= court ? court.name : 'สนามที่ไม่รู้จัก' %>
                            </div>
                            <div class="booking-details">
                                <span>📅 <%= booking.date %></span>
                                <span>🕐 <%= booking.startTime %> - <%= booking.endTime %></span>
                                <span>👤 <%= bookingUser ? bookingUser.username : 'ไม่ทราบ' %></span>
                            </div>
                        </div>
                        <div class="booking-status <%= booking.status %>">
                            <span class="status-dot <%= booking.status %>"></span>
                            <%= booking.status === 'pending' ? 'รอการอนุมัติ' : 'อนุมัติแล้ว' %>
                        </div>
                        <div class="booking-actions">
                            <% if (user.role === 'admin') { %>
                                <% if (booking.status === 'pending') { %>
                                    <form method="POST" action="/bookings/<%= booking.id %>/approve" class="inline-form">
                                        <button type="submit" class="btn btn-success btn-sm">✓ อนุมัติ</button>
                                    </form>
                                <% } %>
                                <form method="POST" action="/bookings/<%= booking.id %>/remove" class="inline-form">
                                    <button type="submit" class="btn btn-danger btn-sm">✗ ลบ</button>
                                </form>
                            <% } else if (booking.userId === user.id) { %>
                                <form method="POST" action="/bookings/<%= booking.id %>/remove" class="inline-form">
                                    <button type="submit" class="btn btn-danger btn-sm">ยกเลิก</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <div class="mt-3">
            <a href="/dashboard" class="btn btn-secondary" id="btn-back-dashboard">← กลับ Dashboard</a>
        </div>
    </div>
</body>
</html>
