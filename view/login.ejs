<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="BaBadminton - ระบบจองสนามแบดมินตันออนไลน์ ง่าย สะดวก รวดเร็ว">
    <title>BaBadminton — เข้าสู่ระบบ</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="bg-decoration"></div>

    <div class="login-page">
        <div class="login-container">
            <div class="login-card">
                <!-- Logo -->
                <div class="login-logo">
                    <span class="icon">🏸</span>
                    <h1>BaBadminton</h1>
                    <p>ระบบจองสนามแบดมินตันออนไลน์</p>
                </div>

                <!-- Error Message -->
                <% if (error) { %>
                    <div class="alert alert-error">
                        ⚠️ <%= error %>
                    </div>
                <% } %>

                <!-- Google OAuth Button -->
                <% if (typeof hasGoogleAuth !== 'undefined' && hasGoogleAuth) { %>
                    <a href="/auth/google" class="btn btn-google btn-lg" style="width: 100%; text-align: center;" id="google-login-btn">
                        <svg viewBox="0 0 24 24" width="20" height="20">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        เข้าสู่ระบบด้วย Google
                    </a>

                    <div class="login-divider">หรือ</div>
                <% } %>

                <!-- Admin Login Section -->
                <div class="login-admin-section">
                    <% if (typeof hasGoogleAuth !== 'undefined' && hasGoogleAuth) { %>
                        <button class="login-admin-toggle" onclick="toggleAdminForm()" id="admin-toggle-btn">
                            🔐 เข้าสู่ระบบสำหรับผู้ดูแลระบบ
                        </button>
                    <% } %>

                    <div class="admin-form <%= (typeof hasGoogleAuth === 'undefined' || !hasGoogleAuth) ? 'show' : '' %>" id="admin-form">
                        <form method="POST" action="/login">
                            <div class="form-group">
                                <label class="form-label">ชื่อผู้ใช้</label>
                                <input type="text" name="username" class="form-control" placeholder="Username" required id="username-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">รหัสผ่าน</label>
                                <input type="password" name="password" class="form-control" placeholder="Password" required id="password-input">
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg" style="width: 100%;" id="admin-login-btn">
                                เข้าสู่ระบบ
                            </button>
                        </form>
                        <p style="text-align: center; margin-top: 16px; font-size: 0.75rem; color: var(--text-muted);">
                            Admin: admin / admin123
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleAdminForm() {
            const form = document.getElementById('admin-form');
            form.classList.toggle('show');
        }
    </script>
</body>
</html>
